# =============================================================================
# MathBattle-BE — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#
#   cp .env.example .env
# =============================================================================


# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development        # development | testing | production
DEBUG=True                     # Set False in production


# -----------------------------------------------------------------------------
# Database (PostgreSQL + asyncpg)
# -----------------------------------------------------------------------------
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@localhost:5432/mathbattle


# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_V1_STR=/api/v1
PROJECT_NAME=MathBattle
PROJECT_VERSION=1.0.0


# -----------------------------------------------------------------------------
# JWT / Security
# -----------------------------------------------------------------------------
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7


# -----------------------------------------------------------------------------
# Email (SendGrid)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=your-sendgrid-api-key-here
EMAIL_FROM=noreply@mathbattle.com
EMAIL_FROM_NAME=MathBattle


# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12               # Recommended: 12 (increase for higher security, slower hashing)


# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=True
REGISTRATION_RATE_LIMIT=5/hour


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8081"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
